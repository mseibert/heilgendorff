---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<!DOCTYPE html>
<html lang="de">
	<head>
		<BaseHead title="Über uns - Steuerbüro Heilgendorff" description="Erfahren Sie mehr über unser Team, unsere Werte und unsere Leidenschaft für die Steuerberatung" />
	</head>
	<body>
		<Header />
		<main id="main-content" class="about-page">
			<section class="hero">
				<div class="hero-content">
					<h1 data-translate="aboutHeroTitle">Über uns</h1>
					<p class="hero-subtitle" data-translate="aboutHeroSubtitle">Erfahren Sie mehr über unser Team, unsere Werte und unsere Leidenschaft für die Steuerberatung</p>
				</div>
			</section>

			<section class="content-section">
				<div class="content-container">
					<div class="founder-section">
						<div class="founder-box">
							<h2 class="founder-headline" data-translate="aboutSubtitle">Wir lieben es zu arbeiten & wir lieben, wo wir arbeiten</h2>
							<p data-translate="aboutText1">Wir beraten Sie in allen betriebswirtschaftlichen und steuerrechtlichen Fragen. Unsere Fachgebiete sind die Steuererklärungsberatung, die Steuerdurchsetzungsberatung und die gestaltende Steuerberatung.</p>
							<p data-translate="aboutText2">Steuerbüro Heilgendorff bietet seinen Mandanten zusätzlich den Zugriff auf den Terminalserver der Kanzlei, um die Kommunikation so einfach und komfortabel wie möglich zu gestalten.</p>
							<p data-translate="aboutText3">Unsere Erfahrung mit unserem branchenübergreifenden Leistungspektrum ermöglicht es uns, schnell und effizient Ihr Anliegen zu bearbeiten.</p>
							<div class="founder-header">
								<h3 data-translate="founderTitle">Burghard Heilgendorff, Kanzleiinhaber</h3>
								<div class="founder-portrait">
									<img src="/1630348104042.jpeg" alt="Burghard Heilgendorff" />
								</div>
							</div>
							<p data-translate="founderText">Die Begleitung eines Unternehmens vom Startup über alle Unternehmensphasen hinweg bietet für mich die größte Herausforderung. Der Mandant wird betreut von der Unternehmensgründung, dem Vermögensaufbau bis zur Altersabsicherung und erbschaftsteuerlichen Gestaltung</p>
						</div>
					</div>

					<section class="team-section">
						<div class="team-content">
							<h3 class="team-heading" data-translate="teamImageTitle">Unser Team</h3>
							<p data-translate="teamText">Unser Team stellt sich zusammen aus Steuerberatern, Steuerfachangestellten, Steuerfachwirten, Betriebswirten und Finanz- und Lohnbuchhaltern sowie Auszubildenden und studentischen Hilfskräften. Zusätzlich unterstützen wir unsere Angestellten, Auszubildenden und Studenten, indem wir zahlreiche Fortbildungsmaßnahmen bieten und ein duales Studium ermöglichen.</p>
							<div class="languages-badges">
								<span class="badge" data-translate="german">Deutsch</span>
								<span class="badge" data-translate="english">Englisch</span>
								<span class="badge" data-translate="french">Französisch</span>
							</div>
						</div>
						<div class="team-kanzlei-image">
							<img src="/bild-der-kanzlei.jpg" alt="Bild der Kanzlei" />
						</div>
					</section>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		background: white;
		color: var(--black);
		width: 100vw;
		padding: 4rem 0;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		left: 50%;
		transform: translateY(-5px);
		right: 50%;
		margin-left: -50vw;
		margin-right: -50vw;
		overflow-x: hidden;
		margin-top: 0;
	}

	.hero-content {
		padding-top: 0;
	}

	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.8rem;
		color: var(--accent);
		font-family: "Merriweather", serif;
	}

	.hero-subtitle {
		font-size: 1.2em;
		opacity: 0.8;
		margin: 0;
		color: var(--black);
		font-family: "IBM Plex Sans", sans-serif;
	}

	.content-section {
		overflow: visible;
		margin: 2.88rem calc(-45vw + 50%) 0 calc(-45vw + 50%);
		padding: 2.88rem 1.44rem 0 1.44rem;
		width: 90vw;
		position: relative;
		left: calc(50% - 10px);
		right: 50%;
		margin-left: calc(-45vw - 10px);
		margin-right: -45vw;
		background: white;
	}

	.content-container {
		width: 95%;
		margin: 0 auto;
		padding: 0 2rem;
		transform: translateX(-15px);
	}

	.founder-section {
		position: relative;
		margin-bottom: 3rem;
	}

	.founder-box {
		background: #f8f9fa;
		padding: 2.5rem 2rem;
		border-radius: 12px;
		border-left: 4px solid var(--accent);
		position: relative;
		z-index: 1;
		overflow: visible;
	}

	.founder-headline {
		font-size: 2.2em;
		margin: 0 0 1.5rem;
		color: var(--accent);
		font-family: "Merriweather", serif;
		text-align: center;
	}

	.founder-box p {
		font-size: 1.1em;
		line-height: 1.6;
		color: var(--black);
		font-family: "IBM Plex Sans", sans-serif;
		margin: 0 0 1rem;
	}

	.founder-box p:last-of-type {
		margin-bottom: 0;
	}

	.founder-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin: 1rem 0;
	}

	.founder-section h3 {
		font-size: 1.5em;
		margin: 0;
		color: var(--accent);
		font-family: "Merriweather", serif;
		flex: 1;
	}

	.founder-portrait {
		flex: 0 0 auto;
	}

	.founder-portrait {
		flex: 0 0 auto;
	}

	.founder-portrait img {
		width: 110px;
		height: 110px;
		border-radius: 50%;
		object-fit: cover;
		border: 3px solid var(--accent);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.team-section {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
		background: #fafbfc;
		padding: 2.5rem;
		border-radius: 12px;
		border: 1px solid #e9ecef;
		margin-bottom: 3rem;
	}

	.team-content {
		flex: 1;
		min-width: 0;
	}

	.team-kanzlei-image {
		flex: 0 0 auto;
		width: 280px;
	}

	.team-kanzlei-image img {
		width: 100%;
		height: auto;
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		display: block;
	}

	.team-heading {
		font-size: 1.5em;
		margin: 0 0 1rem;
		color: var(--accent);
		font-family: "Merriweather", serif;
	}

	.team-section > p {
		font-size: 1.1em;
		line-height: 1.7;
		color: var(--black);
		font-family: "IBM Plex Sans", sans-serif;
		margin: 0 0 1.5rem;
	}

	.languages-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.languages-badges .badge {
		display: inline-block;
		padding: 0.4rem 1rem;
		background: white;
		border: 1px solid var(--accent);
		color: var(--accent);
		border-radius: 2rem;
		font-size: 0.9em;
		font-family: "IBM Plex Sans", sans-serif;
	}

	@media (min-width: 1025px) {
		.about-page .content-section {
			padding-right: 3rem;
			margin-right: 2rem;
		}
	}

	@media (max-width: 1024px) and (min-width: 721px) {
		.content-section {
			width: 100%;
			margin: 2.88rem 0 0 0;
			padding: 2.88rem 2rem;
			left: 0;
			right: 0;
			margin-left: 0;
			margin-right: 0;
			box-sizing: border-box;
		}

		.content-container {
			width: 100%;
			max-width: 100%;
			padding: 0 2rem;
			transform: translateX(-1rem);
			box-sizing: border-box;
		}

		.founder-box {
			padding: 2.5rem 2rem;
		}

		.team-section {
			flex-direction: column;
		}

		.team-kanzlei-image {
			width: 100%;
			max-width: 320px;
			margin: 0 auto;
		}
	}

	@media (max-width: 720px) {
		.hero {
			width: 100vw;
			max-width: 100vw;
			overflow-x: hidden;
		}

		.hero-content {
			width: 100%;
			max-width: 100vw;
			padding: 0 1rem;
			box-sizing: border-box;
		}

		.hero h1 {
			font-size: 2em;
		}

		.founder-headline {
			font-size: 1.8em;
		}

		.content-container {
			padding: 0 1rem;
			padding-right: 1.5rem;
			text-align: left;
			box-sizing: border-box;
		}

		.founder-section {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		.founder-box {
			padding: 2rem 1.5rem;
			width: 100%;
			box-sizing: border-box;
		}

		.founder-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.founder-portrait img {
			width: 90px;
			height: 90px;
		}

		.team-section {
			flex-direction: column;
			padding: 1.5rem;
		}

		.team-kanzlei-image {
			width: 100%;
			max-width: 280px;
			margin: 0 auto;
		}

		.founder-section .founder-box {
			padding: 1.5rem;
		}
	}
</style>

<CookieBanner />